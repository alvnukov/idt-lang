{
  "id": "idt_v8_finite_gate_residuals",
  "kind": "verification_specification",
  "language_version": "v8.0.0",
  "controlled_vocabulary": [
    {
      "term": "finite gate",
      "status": "project_local",
      "domain": "IDT verification",
      "definition": "An executable finite check or finite residual input used by the IDT verifier."
    },
    {
      "term": "residual input",
      "status": "standard",
      "domain": "scientific claim verification",
      "definition": "A structured input that remains below proof status until classified or discharged by a stronger artifact."
    },
    {
      "term": "formal proof",
      "status": "standard",
      "domain": "formal methods",
      "definition": "A machine-checkable proof artifact with a reproducible checker command."
    }
  ],
  "verification_rules": [
    {
      "id": "finite_gate_residual_core_fields_are_declared",
      "applies_to": {
        "collection": "finite_gates"
      },
      "assertions": [
        {
          "predicate": "field_non_empty",
          "field_path": "id"
        },
        {
          "predicate": "field_non_empty",
          "field_path": "type"
        }
      ]
    },
    {
      "id": "finite_gate_residual_status_cannot_claim_formal_proof",
      "applies_to": {
        "collection": "finite_gates"
      },
      "assertions": [
        {
          "predicate": "field_not_in",
          "field_path": "status",
          "forbidden_values": ["formal_proof"]
        }
      ]
    }
  ]
}
