{
  "id": "idt_v8_qm_experiment_residuals",
  "kind": "verification_specification",
  "language_version": "v8.0.0",
  "controlled_vocabulary": [
    {
      "term": "experiment protocol",
      "status": "standard",
      "domain": "experimental science",
      "definition": "A declared procedure, input boundary, and readout discipline for an experiment or executable experiment analogue."
    },
    {
      "term": "readout",
      "status": "standard",
      "domain": "measurement theory",
      "definition": "The reported observable result or table produced by a protocol."
    },
    {
      "term": "claim boundary",
      "status": "standard",
      "domain": "scientific claim verification",
      "definition": "A declared limit on what a result is allowed to support."
    }
  ],
  "verification_rules": [
    {
      "id": "qm_experiment_residual_core_fields_are_declared",
      "applies_to": {
        "collection": "qm_experiments"
      },
      "assertions": [
        {
          "predicate": "field_non_empty",
          "field_path": "id"
        },
        {
          "predicate": "field_non_empty",
          "field_path": "title"
        },
        {
          "predicate": "field_non_empty",
          "field_path": "standard_result"
        },
        {
          "predicate": "field_non_empty",
          "field_path": "stable_invariant"
        },
        {
          "predicate": "field_non_empty",
          "field_path": "claim_boundary"
        },
        {
          "predicate": "field_in",
          "field_path": "status",
          "allowed_values": ["executable_gate"]
        }
      ]
    },
    {
      "id": "qm_experiment_residual_refs_are_grounded",
      "applies_to": {
        "collection": "qm_experiments"
      },
      "assertions": [
        {
          "predicate": "field_non_empty",
          "field_path": "finite_gates[]"
        },
        {
          "predicate": "refs_exist",
          "field_path": "finite_gates[]",
          "reference_collections": ["finite_gates"]
        },
        {
          "predicate": "field_non_empty",
          "field_path": "idt_primitives"
        }
      ]
    }
  ]
}
