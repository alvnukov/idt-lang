{
  "id": "idt_v8_qm_core_obligations",
  "kind": "verification_specification",
  "language_version": "v8.0.0",
  "controlled_vocabulary": [
    {
      "term": "proof obligation",
      "status": "standard",
      "domain": "formal methods",
      "definition": "A theorem, lemma, or verification target that must be discharged before a stronger claim status is allowed."
    },
    {
      "term": "evidence reference",
      "status": "standard",
      "domain": "scientific claim verification",
      "definition": "A grounded reference to a supporting symbol, gate, pattern, theorem card, or obligation."
    },
    {
      "term": "claim boundary",
      "status": "standard",
      "domain": "scientific claim verification",
      "definition": "A declared limit on what a result is allowed to support."
    }
  ],
  "verification_rules": [
    {
      "id": "qm_core_obligation_core_fields_are_declared",
      "applies_to": {
        "collection": "qm_core_proof_obligations"
      },
      "assertions": [
        {
          "predicate": "field_non_empty",
          "field_path": "id"
        },
        {
          "predicate": "field_non_empty",
          "field_path": "title"
        },
        {
          "predicate": "field_non_empty",
          "field_path": "scope"
        },
        {
          "predicate": "field_non_empty",
          "field_path": "claim_boundary"
        },
        {
          "predicate": "field_in",
          "field_path": "status",
          "allowed_values": [
            "regression_supported",
            "target",
            "derived_conditional",
            "blocked"
          ]
        }
      ]
    },
    {
      "id": "qm_core_obligation_refs_are_grounded",
      "applies_to": {
        "collection": "qm_core_proof_obligations"
      },
      "assertions": [
        {
          "predicate": "refs_exist",
          "field_path": "depends_on[]",
          "reference_collections": ["qm_core_proof_obligations"]
        },
        {
          "predicate": "field_non_empty",
          "field_path": "evidence_refs[]"
        },
        {
          "predicate": "refs_exist",
          "field_path": "evidence_refs[]",
          "reference_collections": [
            "symbols",
            "finite_gates",
            "qm_universal_patterns",
            "theorem_cards",
            "qm_core_proof_obligations"
          ]
        }
      ]
    }
  ]
}
